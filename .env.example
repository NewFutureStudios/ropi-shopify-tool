# Shopify OAuth credentials (via dev.shopify.com → jouw app → Settings)
SHOPIFY_CLIENT_ID=f8e09dee426b6894bf5fce715b0f4900
SHOPIFY_CLIENT_SECRET=jouw-client-secret-hier

# Flask sessie sleutel (willekeurige string, verander dit in productie)
FLASK_SECRET_KEY=verander-dit-naar-iets-geheims

# Bol.com Retailer API credentials (via partner.bol.com → Instellingen → API-toegang)
BOL_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOL_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub backup voor snapshots (github.com/settings/tokens → repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_SNAPSHOTS_REPO=NewFutureStudios/ropi-snapshots
